    <!-- ANA İÇERİK: BAKİYE EKLE -->
    <main class="page-container">
        
        <!-- Üst Küçük Modern Banner -->
        <div class="bakiye-banner">
            <div class="banner-left">
                <h1>Hesabınıza Bakiye Yükleyin</h1>
                <p>Güvenli ödeme altyapımız ile 7/24 anında, kesintisiz bakiye yükleyip favori oyunlarınızda alışverişe hemen başlayabilirsiniz.</p>
            </div>
            <div class="banner-right">
                <span>Mevcut Bakiyeniz</span>
                <div class="amount">0.00 <sub>TL</sub></div>
            </div>
        </div>

        <!-- Ödeme Yöntemi Kartları -->
        <div>
            <h2 class="section-title"><i class="ri-wallet-3-line"></i> Ödeme Yöntemi Seçin</h2>
            <div class="payment-methods">
                
                <!-- Kredi Kartı -->
                <div class="payment-card active">
                    <div class="pay-badge">Anında</div>
                    <div class="pay-icon-wrapper" style="color: #60a5fa;"><i class="ri-bank-card-line"></i></div>
                    <div class="pay-info">
                        <h3>Kredi / Banka Kartı</h3>
                        <p>3D Secure ile güvenli ödeme. Tüm kartlar geçerlidir.</p>
                    </div>
                </div>

                <!-- Havale/EFT -->
                <div class="payment-card">
                    <div class="pay-badge">Hızlı</div>
                    <div class="pay-icon-wrapper" style="color: #34d399;"><i class="ri-exchange-dollar-line"></i></div>
                    <div class="pay-info">
                        <h3>Havale / EFT / FAST</h3>
                        <p>7/24 banka hesaplarımıza anında bakiye transferi yapın.</p>
                    </div>
                </div>

                <!-- Kripto -->
                <div class="payment-card">
                    <div class="pay-badge" style="background: rgba(245, 158, 11, 0.15); color: #f59e0b; border-color: rgba(245, 158, 11, 0.3);">%0 Komisyon</div>
                    <div class="pay-icon-wrapper" style="color: #fbbf24;"><i class="ri-bit-coin-line"></i></div>
                    <div class="pay-info">
                        <h3>Kripto Para</h3>
                        <p>USDT, BTC, ETH ile masrafsız global kripto ödeme.</p>
                    </div>
                </div>

            </div>
        </div>

        <!-- Dinamik Form & Bilgilendirme Panelleri -->
        <div class="deposit-form-area">
            
            <!-- Yükleme Formu -->
            <div class="deposit-form">
                <h3 style="font-size: 18px; color: #fff; margin-bottom: 20px; font-weight: 600;">Yükleme Detayları</h3>
                
                <div class="form-group">
                    <label>Yüklenecek Tutar (TL)</label>
                    <input type="number" id="tutarInput" class="form-control" placeholder="Örn: 100" min="10" step="1">
                </div>

                <div class="amount-options">
                    <div class="amount-btn">+50 TL</div>
                    <div class="amount-btn">+100 TL</div>
                    <div class="amount-btn">+250 TL</div>
                    <div class="amount-btn">+500 TL</div>
                </div>

                <div class="form-group">
                    <label>Kart Üzerindeki İsim Soyisim</label>
                    <input type="text" class="form-control" placeholder="Ad Soyad">
                </div>

                <button class="btn-submit">
                    <i class="ri-shield-check-line"></i> Güvenle Öde
                </button>
                <p style="text-align: center; font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 15px;">Ödeme işlemine devam ederek Gizlilik Politikası ve Şartlar'ı kabul etmiş olursunuz.</p>
            </div>

            <!-- Bilgilendirme ve Güvenlik Kartları -->
            <div class="info-panels">
                
                <div class="info-card secure">
                    <i class="ri-lock-2-line"></i>
                    <div class="info-content">
                        <h4>%100 Güvenli Altyapı</h4>
                        <p>256-bit SSL şifreleme ve 3D Secure koruması ile kart bilgileriniz asla kaydedilmez. Alışverişiniz tamamen güvendedir.</p>
                        <div class="secure-badges">
                            <div class="badge-box"><i class="fa-brands fa-cc-visa"></i> VISA</div>
                            <div class="badge-box"><i class="fa-brands fa-cc-mastercard"></i> MasterCard</div>
                            <div class="badge-box"><i class="ri-shield-keyhole-line"></i> 3D Secure</div>
                        </div>
                    </div>
                </div>

                <div class="info-card">
                    <i class="ri-flashlight-line"></i>
                    <div class="info-content">
                        <h4>Anında Teslimat</h4>
                        <p>Yüklediğiniz bakiye saniyeler içinde hesabınıza geçer. Beklemek yok, anında oyun keyfine devam edebilirsiniz.</p>
                    </div>
                </div>

                <div class="info-card support">
                    <i class="ri-customer-service-2-line"></i>
                    <div class="info-content">
                        <h4>7/24 Canlı Destek</h4>
                        <p>Ödeme sırasında veya sonrasında bir sorun mu yaşadınız? Destek ekibimiz size yardımcı olmak için her an hazır.</p>
                        <a href="#" style="color: #ec4899; font-size: 12px; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 8px;">Desteğe Bağlan <i class="ri-arrow-right-line"></i></a>
                    </div>
                </div>

            </div>
        </div>

    </main>

    <!-- MOBİL ALT MENÜ (Bakiye Sekmesi Aktif Edildi) -->
    <div class="mobile-bottom-menu">
        <a href="index.html" class="bottom-menu-item">
            <i class="ri-home-5-line"></i><span>Ana Sayfa</span>
        </a>
        <a href="#" class="bottom-menu-item">
            <i class="ri-search-line"></i><span>Ara</span>
        </a>
        <a href="bakiye-ekle.html" class="bottom-menu-item active">
            <i class="ri-wallet-3-line"></i><span>Bakiye</span>
        </a>
        <a href="#" class="bottom-menu-item">
            <i class="ri-message-3-line"></i><span>Mesajlar</span>
        </a>
        <a href="#" class="bottom-menu-item">
            <i class="ri-user-line"></i><span>Hesabım</span>
        </a>
    </div>

    <!-- Temel Etkileşim Scripti (İsteğe Bağlı) -->
    <script>
        // Ödeme kartı seçimi etkileşimi
        const cards = document.querySelectorAll('.payment-card');
        cards.forEach(card => {
            card.addEventListener('click', () => {
                cards.forEach(c => c.classList.remove('active'));
                card.classList.add('active');
            });
        });

        // Hızlı tutar seçme butonları
        const amountBtns = document.querySelectorAll('.amount-btn');
        const amountInput = document.getElementById('tutarInput');
        amountBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const val = btn.innerText.replace('+','').replace(' TL','');
                const currentVal = amountInput.value ? parseInt(amountInput.value) : 0;
                amountInput.value = currentVal + parseInt(val);
                
                // Küçük bir tıklama geri bildirimi animasyonu
                amountInput.style.borderColor = '#10b981';
                amountInput.style.boxShadow = '0 0 0 3px rgba(16, 185, 129, 0.2)';
                setTimeout(() => { 
                    amountInput.style.borderColor = ''; 
                    amountInput.style.boxShadow = ''; 
                }, 400);
            });
        });
    </script>
</body>
</html>